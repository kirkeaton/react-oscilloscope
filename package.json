{
  "name": "react-oscilloscope",
  "version": "0.0.0-development",
  "description": "React component for an oscilloscope",
  "author": "Kirk Eaton <contact@kirkeaton.ca>",
  "bugs": {
    "url": "https://github.com/kirkeaton/react-oscilloscope/issues"
  },
  "devDependencies": {
    "@kirkeaton/prettier-config": "1.0.2",
    "@kirkeaton/tsconfig": "1.0.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "prettier": "3.3.3",
    "serve": "14.2.6",
    "typescript": "5.6.3"
  },
  "engines": {
    "node": ">=20"
  },
  "homepage": "https://github.com/kirkeaton/react-oscilloscope#readme",
  "keywords": [
    "oscilloscope",
    "react"
  ],
  "license": "BSD-3-Clause",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kirkeaton/react-oscilloscope.git"
  },
  "scripts": {
    "build": "npm run clean && tsc && cp index.html dist/index.html",
    "clean": "rm -rf dist",
    "format": "prettier \"**/*.{html,json,md,ts,tsx}\" --write",
    "lint": "prettier \"**/*.{html,json,md,ts,tsx}\" --check",
    "start": "npm run build && serve dist",
    "typecheck": "tsc --noEmit"
  },
  "type": "module"
}
